btree_prng_seed:{sim_prng_seed}
replicator_prng_seed:{sim_prng_seed}
loop_prng_seed:{sim_prng_seed}
{input_state}
load_BD_lengths:./BD_lengths.txt
load_mono_coords:{dna_monomers_path},row
load_ribo_coords:{ribos_path},row
{load_boundary}
prepare_simulator:{output_dir}{run_name}.log
simulator_set_prng_seed:{sim_prng_seed}
simulator_set_nProc:8
simulator_set_DNA_model:/Software/btree_chromo/LAMMPS_DNA_model_kk
#simulator_set_DNA_model:/Software/btree_chromo/LAMMPS_DNA_model_kk
simulator_set_output_details:{output_dir},{run_name}
simulator_set_delta_t:2.0E+7
dump_topology:{output_dir}chromo_topo.dat,1
switch_twisting_angles:F
switch_ellipsoids:F

# initial frame
sys_write_sim_read_LAMMPS_data:{output_dir}data_{run_name}.lammps
simulator_load_loop_params:loop_params.txt
{load_loops}
simulator_run_soft_harmonic:10000,1000,20000,{append_string}

# if initial run, equilibrate loops for 1 hour (3600 s * 100 beads / s)
{equilibrate_loops}

# run for 12 seconds of bio time (6 batches of 2 seconds) with dynamics
repeat:30
sync_simulator_and_system
set_initial_state
transform:m_cw20_ccw20
set_final_state
output_state:{output_dir}/rep_states/rep_state_{run_name}.txt
map_replication
write_loops:{output_dir}/loops/loops_{run_name}.txt
sys_write_sim_read_LAMMPS_data:{output_dir}data_{run_name}.lammps
translocate:50,T
sys_write_sim_read_LAMMPS_data:{output_dir}data_{run_name}.lammps
simulator_form_loops:F
simulator_minimize_topoDNA_harmonic:1000
simulator_set_delta_t:2.5E+7
simulator_set_DNA_model:/Software/btree_chromo/LAMMPS_DNA_model_kk
{run_dynamics}
#simulator_set_DNA_model:/Software/btree_chromo/LAMMPS_DNA_model_kk
#{run_dynamics}
end_repeat

sync_simulator_and_system
write_mono_coords:{dna_monomers_dir}dna_{run_name}_{next_timestep}_preequil.bin,row
#simulator_set_DNA_model:/Software/btree_chromo/LAMMPS_DNA_model_kk
#{run_dynamics}


# equilibrate dna and ribos
simulator_set_DNA_model:/Software/btree_chromo/LAMMPS_DNA_model_kk
simulator_run_soft_harmonic:500000,1000,10000,append,nofirst

sync_simulator_and_system

# run for 48 seconds of bio time (24 batches of 2 seconds) without dynamics
#repeat:24
#set_initial_state
#transform:m_cw20_ccw20
#set_final_state
#output_state:{output_dir}/rep_states/rep_state_{run_name}.txt
#map_replication
#write_loops:{output_dir}/loops/loops_{run_name}.txt
#translocate:50,T
#end_repeat

write_mono_coords:{dna_monomers_dir}dna_{run_name}_{next_timestep}.bin,row
write_ribo_coords:{dna_monomers_dir}ribo_{run_name}_{next_timestep}.bin,row
write_loops:{output_dir}loops/loops_{run_name}_{next_timestep}.txt
output_state:{output_dir}rep_states/rep_state_{run_name}_{next_timestep}.txt
