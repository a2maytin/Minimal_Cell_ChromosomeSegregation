# create springs to hold ribosomes
variable ribos_spring equal 1.0*${kBT}
fix ribosSpring ribos spring/self ${ribos_spring}

# include file with description of DNA model for minimization
include ${DNA_model_dir}/lmp.twistable_DNA_model_StiffBonds_omp

# set the neighbor type
neighbor ${r_ribo} bin
neigh_modify every 1 delay 5 check yes page 100000 exclude type 1 1

# compute angle contributions
compute angleE all angle
thermo		${T_freq_m}
thermo_style custom step emol epair ebond eangle c_angleE[1] c_angleE[2] c_angleE[3]

# minimize the system with soft potentials

include ${DNA_model_dir}lmp.DNA_pair_soft_omp

min_style cg
minimize 1.0e-5 1.0e-7 40000 400000

# minimize the system with hard potentials

include ${DNA_model_dir}lmp.DNA_pair_LJcut_omp

min_style cg
#minimize 1.0e-5 1.0e-7 20000 200000

# minimize the system with hard potentials

include ${DNA_model_dir}lmp.twistable_DNA_model_FENE_omp

min_style cg
minimize 1.0e-5 1.0e-7 20000 200000

# release ribosomes from springs following minimization
unfix ribosSpring
